COMMISSION DES OPERATIONS DE BOURSE  , 
AUTORITE DE REGULATION DES COMMUNICATIONS ELECTRONIQUES ET DES POSTES  , 
AUTORITE DE CONTROLE DES ASSURANCES ET DES MUTUELLES  , 
COMMISSION BANCAIRE  , 
@example CONSEIL SUPERIEUR DE L'AUDIOVISUEL (CSA)
-->
<!ELEMENT AUTORITE (#PCDATA) >

<!-- 
Ministère émetteur 
@exemple MINISTERE DE L'EMPLOI ET DE LA SOLIDARITE
-->
<!ELEMENT MINISTERE (#PCDATA) >

<!-- 
Liste des mots clé du texte 
-->
<!ELEMENT MCS_TEXT (MC*) >

<!-- 
Libellé du mot clé
@example DETTE COMMERCIALE
-->
<!ELEMENT MC (#PCDATA) >

<!-- 
Liste des liens entrants ou sortant 
-->
<!ELEMENT LIENS (LIEN*) >

<!-- 
Libellé du lien entrant ou sortant vers un autre texte.
-->
<!ELEMENT LIEN (#PCDATA) >

<!-- 
Numéro de l'article si le lien porte sur un article 
@example 2-4
-->
<!ATTLIST LIEN num CDATA #REQUIRED>

<!-- 
Identifiant interne de l'article ou du texte 
@example JORFTEXT000001422418
-->
<!ATTLIST LIEN id CDATA #REQUIRED>

<!-- 
Type du lien 
@hidden Liste de valeurs à preciser 
-->
<!ATTLIST LIEN typelien CDATA #REQUIRED>

<!-- 
Sens du lien.
Peut prendre les valeurs "cible" ou "source".
@example cible
-->
<!ATTLIST LIEN sens (cible|source) "cible">

<!-- 
Identifiant interne de la version d'origine du texte. 
@example JORFTEXT000004585864
-->
<!ATTLIST LIEN cidtexte CDATA #REQUIRED>

<!-- 
Nature du texte. 
@hidden Liste de valeurs à preciser 
@example DECRET
-->
<!ATTLIST LIEN naturetexte CDATA #REQUIRED>

<!-- 
Numéro du texte 
@example 2001-1369
-->
<!ATTLIST LIEN numtexte CDATA #REQUIRED>

<!-- 
NOR du texte 
@example PRMX0105298D
-->
<!ATTLIST LIEN nortexte CDATA #REQUIRED>

<!-- 
Date de signature du texte 
@example 2001-12-31
-->
<!ATTLIST LIEN datesignatexte CDATA #REQUIRED>

<!-- 
Notice du texte. 
Contenu formaté en HTML. 
-->
<!ELEMENT NOTICE (CONTENU) >

<!-- 
Visas du texte. 
Contenu formaté en HTML. 
-->
<!ELEMENT VISAS (CONTENU) >

<!-- 
Signataires du texte 
Contenu formaté en HTML. 
-->
<!ELEMENT SIGNATAIRES (CONTENU) >

<!-- 
Abrogations du texte 
Contenu formaté en HTML. 
-->
<!ELEMENT ABRO (CONTENU) >

<!-- 
Rectifications du texte 
Contenu formaté en HTML. 
-->
<!ELEMENT RECT (CONTENU) >

<!-- 
Résumé LEX  
Contenu formaté en HTML. 
-->
<!ELEMENT SM (CONTENU)>

<!-- 
Travaux préparatoires du texte 
Contenu formaté en HTML. 
-->
<!ELEMENT TP (CONTENU)>

<!-- 
Structure du texte. 
Contient la liste des sections et des articles composant ce texte. 
-->
<!ELEMENT STRUCT ((SECTION_TA|ARTICLE)*,SIGNATAIRES)>

<!-- 
Section du sommaire du texte 
-->
<!ELEMENT SECTION_TA (ID, TITRE_TA, COMMENTAIRE?, (SECTION_TA | ARTICLE)*)> 

<!-- 
Libelle de la section
@example TITRE Ier :   DISPOSITIONS GENERALES
-->
<!ELEMENT TITRE_TA (#PCDATA)>

<!-- 
Commentaire sur la section
@example Le présent chapitre ne comporte pas de dispositions réglementaires
-->
<!ELEMENT COMMENTAIRE (#PCDATA)>

<!-- 
Article du texte 
-->
<!ELEMENT ARTICLE (ID, ID_ELI?, ELI_ALIAS?, ANCIEN_ID, NUM, MCS_ART, DATE_DEBUT, DATE_FIN, SM, BLOC_TEXTUEL, LIENS?) >

<!-- 
Liste des mots clés de l'article
-->
<!ELEMENT MCS_ART (MC*) >

<!-- 
Date d'entrée en vigueur de l'article 
@example 2003-08-23
-->
<!ELEMENT DATE_DEBUT (#PCDATA) >

<!-- 
Date de fin de vigueur de l'article 
@example 2999-01-01
-->
<!ELEMENT DATE_FIN (#PCDATA) >

<!-- 
Contenu textuel de l'article 
Contenu formaté en HTML. 
-->
<!ELEMENT BLOC_TEXTUEL (CONTENU) >

<!--
Rubrique entreprise
-->
<!ELEMENT ENTREPRISE (DATES_EFFET?, DOMAINES?)>

<!--
Texte entreprise
-->
<!ATTLIST ENTREPRISE texte_entreprise CDATA #REQUIRED>

<!--
Dates d'effet (entreprise)
-->
<!ELEMENT DATES_EFFET (DATE_EFFET*)>

<!--
Date d'effet (entreprise)
-->
<!ELEMENT DATE_EFFET (#PCDATA)>

<!--
Domaines (entreprise)
-->
<!ELEMENT DOMAINES (DOMAINE*)>

<!--
Domaine (entreprise)
-->
<!ELEMENT DOMAINE (#PCDATA)>
