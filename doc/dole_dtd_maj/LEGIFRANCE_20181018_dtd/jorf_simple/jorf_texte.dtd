<?xml version="1.0" encoding="UTF-8"?>

<!--
Décrit la structure d'un document de type texte JORF destiné aux licenciés Legifrance.
@title JORF simplifié : Texte
@root TEXTE
-->

<!-- Inclusion de la redefinition du contenu html -->
<!ENTITY % contenu SYSTEM "contenu.dtd" > 
%contenu;

<!-- Racine du texte JORF-->
<!ELEMENT TEXTE (ID, ID_ELI?, ELI_ALIAS?, ANCIEN_ID, ORIGINE, NATURE, NUM, NUM_PARUTION, NUM_SEQUENCE, NOR, DATE_PUBLI, DATE_TEXTE, ORIGINE_PUBLI,PAGE_DEB_PUBLI, PAGE_FIN_PUBLI, TITRE, TITREFULL, AUTORITE,MINISTERE,MCS_TEXT,LIENS?,NOTICE?,VISAS,ABRO,RECT,SM,TP,STRUCT,ENTREPRISE?)>
<!ELEMENT ELI_ALIAS (ID_ELI_ALIAS*)>

<!-- 
Identifiant interne du document. 
L'identifiant est également le nom du fichier xml. 
@example JORFTEXT000001422418
-->
<!ELEMENT ID (#PCDATA) >

<!-- Identifiant eli. Il est optionnel et concerne les conteneurs, les textes et les articles.
    @example pour le texte dont le NOR est EFIT1318746D : eli/decret/2014/1/27/EFIT1318746D/jo/texte
-->
<!ELEMENT ID_ELI (#PCDATA) >

<!-- Alias de l'identifiant eli. Il est optionnel et concerne certains textes numérotés (lois, ordonnances, décrets) et leurs articles.
    @example pour le texte dont le numéro est 2014-59 : eli/decret/2014/1/27/2014-59/jo/texte
-->
<!ELEMENT ID_ELI_ALIAS (#PCDATA) >

<!-- 
Ancien identifiant issu de la version précédente de légifrance. 
Cette information est conservée afin d'assurer la résolution des URL à l'ancien format du site Legifrance 
@example AFHBT
-->
<!ELEMENT ANCIEN_ID (#PCDATA) >

<!-- 
Origine du document. 
@hidden Liste de valeurs à preciser lors de la reprise des directives europeennes
@example JORF
-->
<!ELEMENT ORIGINE (#PCDATA) >

<!-- 
Nature du document. 
Liste des valeurs en date du 12/06/2008 :
