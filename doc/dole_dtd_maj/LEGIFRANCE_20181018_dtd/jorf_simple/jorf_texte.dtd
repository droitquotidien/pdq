DECISION_EURO  , 
DECLARATION  , 
DECLARATIONEURO  , 
DECRET  , 
DECRETEURO  , 
DECRETLOIEURO  , 
DECRETSEURO  , 
DECRET_LOI  , 
DELEGATION  , 
DELEGATIONDEGESTION  , 
DELIBERATION  , 
DELIBERATIONEURO  , 
DESIGNATION  , 
DEUXIEME  , 
DIRECTIVE  , 
DIRECTIVE_EURO  , 
DISPOSITIONS  , 
DIXIEME  , 
DOUZIEME  , 
ELECTION  , 
ELECTIONDUPRESIDENTDELAREPUBLIQU  , 
ELECTIONPRESIDENTIELLECONSEILCON  , 
EURO  , 
EXEQUATUR  , 
EXTRAIT  , 
FINEURO  , 
HOMMAGENATIONAL  , 
HUITIEME  , 
ICONSTRUCTEUR66ARRETE  , 
INCOMPATIBILITEEURO  , 
INFORMATION  , 
INFORMATIONEURO  , 
INFORMATIONSEURO  , 
INSTRUCTION  , 
INSTRUCTIONEURO  , 
JUGEMENTEURO  , 
LETTRE  , 
LETTREEURO  , 
LISTE  , 
LOI  , 
LOIEURO  , 
LOI_CONSTIT  , 
LOI_ORGANIQUE  , 
LOI_PROGRAMME  , 
MEDAILLEMILITAIRE  , 
MEMOIRE  , 
MESSAGE  , 
MODIFICATIF  , 
MODIFICATION  , 
NEUVIEME  , 
NOMENCLATURE  , 
NOTE  , 
OBSERVATION  , 
OBSERVATIONSEURO  , 
ONZIEME  , 
ORDONNANCE  , 
ORDONNANCEEURO  , 
PREMIER  , 
PROCLAMATION  , 
PROJET  , 
PROMOTIONSPECIALEDUCINQUANTIEMEA  , 
PROPOSITION  , 
PROTOCOLE  , 
PUBLICATION  , 
QUATRIEME  , 
QUESTIONEURO  , 
RAPPORT  , 
RECOMMANDATION  , 
RECOMMANDATION_EURO  , 
RECTIFICATIF  , 
REGLEMENT  , 
REGLEMENTEUROPEEN  , 
RELEVE  , 
REMISE  , 
RESULTATS  , 
RESULTATSDUTIRAGE  , 
