<?xml version="1.0" encoding="UTF-8"?>

<!-- Métadonnées communes à tous les documents Legifrance 
    @title Métadonnées communes
    @root META_COMMUN
-->

<!-- Racine du document -->
<!ELEMENT META_COMMUN (ID, ID_ELI?, ELI_ALIAS?, ANCIEN_ID, ORIGINE, URL, NATURE)>
<!ELEMENT ELI_ALIAS (ID_ELI_ALIAS*)>

<!-- Identifiant interne. L'identifiant est également le nom du fichier xml. 
    @example JORFCONT000000755641
-->
<!ELEMENT ID (#PCDATA) >

<!-- Identifiant eli. Il est optionnel et concerne les conteneurs, les textes et les articles.
    @example pour le texte dont le NOR est EFIT1318746D : eli/decret/2014/1/27/EFIT1318746D/jo/texte
-->
<!ELEMENT ID_ELI (#PCDATA) >

<!-- Alias de l'identifiant eli. Il est optionnel et concerne certains textes numérotés (lois, ordonnances, décrets) et leurs articles.
    @example pour le texte dont le numéro est 2014-59 : eli/decret/2014/1/27/2014-59/jo/texte
-->
<!ELEMENT ID_ELI_ALIAS (#PCDATA) >

<!-- Ancien identifiant issu de la version précédente de légifrance. Cette information est conservée afin d'assurer la résolution des URL à l'ancien format du site Legifrance -->
<!ELEMENT ANCIEN_ID (#PCDATA) >

<!-- Origine du document. 
    @hidden Liste de valeurs à preciser 
-->
<!ELEMENT ORIGINE (#PCDATA) >

<!-- Adresse physique relative du document dans la hierachie Legifrance -->
<!ELEMENT URL (#PCDATA) >

