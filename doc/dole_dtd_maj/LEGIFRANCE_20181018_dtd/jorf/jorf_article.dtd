<!--
Décrit toutes les informations relatives à un article JORF destiné aux licenciés Legifrance.
@title JORF : Article
@root ARTICLE
-->

<!-- Racine de l'article-->
<!ELEMENT ARTICLE (META, CONTEXTE, VERSIONS, SM, BLOC_TEXTUEL, LIENS?)>

<!ENTITY % meta_commun SYSTEM "meta_commun.dtd" > %meta_commun;
<!ENTITY % lien_art SYSTEM "lien_art.dtd" > %lien_art;
<!ENTITY % lien SYSTEM "lien.dtd" > %lien;
<!ENTITY % contenu SYSTEM "contenu.dtd" > %contenu;

<!-- 
Métadonnées de l'article
-->
<!ELEMENT META (META_COMMUN, META_SPEC) >

<!-- 
Métadonnées spécifiques à ce type de document 
-->
<!ELEMENT META_SPEC (META_ARTICLE) >

<!-- 
Metadonnees specifiques aux articles 
-->
<!ELEMENT META_ARTICLE (NUM, MCS_ART, DATE_DEBUT,  DATE_FIN, TYPE)>

<!-- 
Numéro de l'article 
@example 2-4
-->
<!ELEMENT NUM (#PCDATA)>

<!-- 
Liste des mots clés de l'article 
-->
<!ELEMENT MCS_ART (MC*) >

<!-- 
Libellé du mot clé 
@example PNEUMO-PHTISIOLOGUE
-->
 <!ELEMENT MC (#PCDATA)>

<!-- 
Date d'entrée en vigueur de l'article 
@example 2004-08-23
-->
<!ELEMENT DATE_DEBUT (#PCDATA) >

<!-- 
Date de fin de vigueur de l'article 
@example 2006-09-20
-->
<!ELEMENT DATE_FIN (#PCDATA) >

<!-- Définie le type de l'article
@hidden liste de valeurs à préciser 
-->
<!ELEMENT TYPE (#PCDATA) >

<!-- 
Rappel du contexte de l'article courant. 
Cite le texte parent et ses différentes versions.
-->
<!ELEMENT CONTEXTE (TEXTE)>

<!-- 
Rappel du texte parent et de ses différentes versions
-->
<!ELEMENT TEXTE (TITRE_TXT*, TM*)>

<!-- 
Identifiant interne commun à toute les versions du texte
@example JORFTEXT000004585864
-->
<!ATTLIST TEXTE cid CDATA #REQUIRED >

<!-- 
Numéro du texte 
@example 1992-05-21
-->
<!ATTLIST TEXTE num CDATA #REQUIRED>

<!-- 
NOR du texte
@example SANM0621931S
-->
<!ATTLIST TEXTE nor CDATA #REQUIRED>

